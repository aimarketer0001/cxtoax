# Database (SQLite for local MVP; swap to a PostgreSQL URL for production)
DATABASE_URL="file:./dev.db"

# Admin auth
ADMIN_PASSWORD=
ADMIN_AUTH_SECRET=

# LLM (OpenAI-compatible). Leave LLM_API_KEY empty to always use the rule-based fallback report.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# App
APP_BASE_URL=
NEXT_PUBLIC_SITE_URL=https://cxtoax.vercel.app
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Notifications (server-only; never prefix this variable with NEXT_PUBLIC_)
DISCORD_WEBHOOK_URL=

# Feature flags
AI_REPORT_ENABLED=true
PUBLIC_DIAGNOSIS_ENABLED=true
ADMIN_EDIT_ENABLED=false
