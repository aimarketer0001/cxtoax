# Free deployment example: Vercel Hobby + Supabase Free Postgres
#
# Use the Supabase Postgres connection string.
# Example:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
DATABASE_URL=

# Change both before deployment.
ADMIN_PASSWORD=
ADMIN_AUTH_SECRET=

# Keep empty for fully free operation. The app will use the rule-based report.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# Replace with your deployed Vercel URL or custom domain.
APP_BASE_URL=
NEXT_PUBLIC_SITE_URL=https://cxtoax.vercel.app
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Notifications (server-only; never prefix this variable with NEXT_PUBLIC_)
DISCORD_WEBHOOK_URL=

# Free operation defaults.
AI_REPORT_ENABLED=false
PUBLIC_DIAGNOSIS_ENABLED=true
ADMIN_EDIT_ENABLED=false
